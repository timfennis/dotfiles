# Dismiss after 30 seconds
default-timeout=60000

# Icon directory
icon-path=/usr/share/icons/Adwaita:/usr/share/pixmaps

# Positioning
anchor=top-right
layer=overlay
margin=12

# Appearance
font=Hack Nerd Font 11
width=380
height=120
padding=16
border-size=3
border-radius=8
max-icon-size=48

# Colors
background-color=#282828
text-color=#f2f4f8
border-color=#78a9ff
progress-color=over #353535

# Urgency overrides
[urgency=low]
border-color=#525253
default-timeout=5000

[urgency=high]
border-color=#ee5396
default-timeout=0
